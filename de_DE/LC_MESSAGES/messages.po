msgstr "Großschreibung"

#: modules/Serviceapikey/templates/admin/mod_serviceapikey_config.html.twig:45
#: modules/Serviceapikey/templates/admin/mod_serviceapikey_manage.html.twig:70
msgid "Lowercase"
