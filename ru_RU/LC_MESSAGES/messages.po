msgstr "Опции регистра API ключа"

#: modules/Serviceapikey/templates/admin/mod_serviceapikey_config.html.twig:44
#: modules/Serviceapikey/templates/admin/mod_serviceapikey_manage.html.twig:69
msgid "Uppercase"
msgstr "Верхний регистр"

#: modules/Serviceapikey/templates/admin/mod_serviceapikey_config.html.twig:45
#: modules/Serviceapikey/templates/admin/mod_serviceapikey_manage.html.twig:70
msgid "Lowercase"
msgstr "Нижний регистр"

